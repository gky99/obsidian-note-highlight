{
  "name": "marginalia",
  "version": "0.3.0",
  "description": "Obsidian plugin: PDF-style annotation for web clips and Markdown notes, with non-destructive sidecar storage and content-based re-anchoring.",
  "type": "module",
  "main": "main.js",
  "scripts": {
    "dev": "vite build --watch",
    "build": "tsc --noEmit && vite build",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "wdio run ./test/playground/wdio.conf.mts",
    "pretest:e2e": "pnpm build",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "obsidian",
    "annotation",
    "highlight",
    "web-clip"
  ],
  "license": "MIT",
  "devDependencies": {
    "@codemirror/language": "^6.10.1",
    "@codemirror/state": "^6.4.1",
    "@codemirror/view": "^6.26.3",
    "@types/diff-match-patch": "^1.0.36",
    "@types/js-yaml": "^4.0.9",
    "@types/mocha": "^10.0.10",
    "@types/node": "^20.12.7",
    "@wdio/cli": "^9.29.0",
    "@wdio/globals": "^9.29.0",
    "@wdio/local-runner": "^9.29.0",
    "@wdio/mocha-framework": "^9.29.0",
    "@wdio/spec-reporter": "^9.29.0",
    "builtin-modules": "^3.3.0",
    "happy-dom": "^20.10.6",
    "mocha": "^10.8.2",
    "obsidian": "^1.5.7",
    "tsx": "^4.22.4",
    "typescript": "^5.4.5",
    "vite": "^5.2.10",
    "vitest": "^1.6.0",
    "wdio-obsidian-reporter": "^3.1.1",
    "wdio-obsidian-service": "^3.1.1",
    "webdriverio": "^9.29.0"
  },
  "dependencies": {
    "diff-match-patch": "^1.0.5",
    "js-yaml": "^4.1.0"
  }
}
